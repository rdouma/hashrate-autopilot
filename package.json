{
  "name": "hashrate-autopilot",
  "version": "0.1.0",
  "description": "Autopilot and monitor for renting hashrate from marketplaces (Braiins Hashpower today, marketplace-agnostic by design) and routing it to your own Ocean non-custodial mining pool.",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "pnpm -w run lint && pnpm -w run typecheck && pnpm -w run test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "smoke": "tsx scripts/smoke-braiins.ts",
    "setup": "tsx scripts/setup.ts",
    "daemon": "tsx packages/daemon/src/main.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@hashrate-autopilot/braiins-client": "workspace:*",
    "@hashrate-autopilot/daemon": "workspace:*",
    "@hashrate-autopilot/shared": "workspace:*",
    "@inquirer/prompts": "^8.5.2",
    "@types/node": "^25.9.2",
    "eslint": "^10.4.1",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8",
    "yaml": "^2.9.0"
  }
}
