{
  "name": "braiins-hashrate-control",
  "version": "0.1.0",
  "description": "Autopilot and monitor for the Braiins Hashpower marketplace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "pnpm -w run lint && pnpm -w run typecheck && pnpm -w run test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "smoke": "tsx scripts/smoke-braiins.ts",
    "setup": "tsx scripts/setup.ts",
    "daemon": "tsx packages/daemon/src/main.ts"
  },
  "devDependencies": {
    "@hashrate-autopilot/braiins-client": "workspace:*",
    "@hashrate-autopilot/daemon": "workspace:*",
    "@hashrate-autopilot/shared": "workspace:*",
    "@eslint/js": "^10.0.1",
    "@inquirer/prompts": "^8.5.0",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.0",
    "prettier": "^3.8.3",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.7",
    "yaml": "^2.9.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ],
    "overrides": {
      "fast-uri": ">=3.1.2"
    }
  }
}
