node_modules/
dist/
coverage/
*.log
.DS_Store

# runtime data
data/
*.db
*.db-wal
*.db-shm

# secrets — nothing is committed, including the sops-encrypted envelope.
# Each operator generates their own age key and .env.sops.yaml on first
# install via `pnpm run setup`; the repo carries no per-operator state.
.env
.env.local
.env.*.local
.env.sops.yaml
!.env.example

# editor / tool caches
.vite/
.cache/
.tsbuildinfo
*.tsbuildinfo

# Vite / Vitest
.vitest-cache/

# IDE / local tool state
.idea/

# Keep .claude/commands/ (project slash-commands) but ignore everything else
# at any nesting depth (scripts/.claude/, packages/*/.claude/, ...).
**/.claude/*
!**/.claude/commands/

braiins_hashrate_control.iml
