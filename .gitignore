dist/
coverage/
*.log
.DS_Store

# runtime data
data/
*.db
*.db-wal
*.db-shm

# secrets — nothing is committed, including the sops-encrypted envelope.
# Each operator generates their own age key and .env.sops.yaml on first
# install via `pnpm run setup`; the repo carries no per-operator state.
.env
.env.local
.env.*.local
.env.sops.yaml
!.env.example

# editor / tool caches
.vite/
.cache/
.tsbuildinfo
*.tsbuildinfo

# Vite / Vitest
.vitest-cache/

# Lingui compiled message catalogs (#1). The `.po` files are the
# human-edited source of truth and are committed; the `.ts` files
# are derived output from `pnpm lingui:compile`, regenerated by
# the dashboard's `build` script before every Vite build.
packages/dashboard/src/locales/*/messages.ts

# IDE / local tool state
.idea/

# `.claude/` and the permissions log are operator-private working
# artefacts (slash-command tweaks, agent permission audit trails) -
# not interesting to anyone reading the repo. Ignore at any nesting
# depth.
**/.claude/
docs/permissions-log.md

braiins_hashrate_control.iml
scripts/dump-clarent.sh
scripts/test-stratum.sh

# Operator-private working files at the repo root - analysis
