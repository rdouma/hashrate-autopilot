{
  "name": "@hashrate-autopilot/braiins-client",
  "version": "0.1.0",
  "description": "Typed client for the Braiins Hashpower marketplace REST API",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b tsconfig.json --force",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "codegen": "openapi-typescript ./openapi.yml -o ./src/generated/types.ts"
  },
  "dependencies": {
    "@hashrate-autopilot/shared": "workspace:*",
    "openapi-fetch": "^0.17.0"
  },
  "devDependencies": {
    "openapi-typescript": "^7.13.0"
  }
}
