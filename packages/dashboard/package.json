{
  "name": "@braiins-hashrate/dashboard",
  "version": "0.1.0",
  "description": "React SPA for the Braiins hashrate autopilot",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm lingui:compile && tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "lingui:extract": "lingui extract --clean",
    "lingui:compile": "lingui compile --typescript"
  },
  "dependencies": {
    "@braiins-hashrate/shared": "workspace:*",
    "@lingui/core": "^6.0.1",
    "@lingui/macro": "^5",
    "@lingui/react": "^6.0.1",
    "@tanstack/react-query": "^5.100.11",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1"
  },
  "devDependencies": {
    "@lingui/cli": "^5.9.5",
    "@lingui/vite-plugin": "^5.9.5",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "babel-plugin-macros": "^3.1.0",
    "tailwindcss": "^4.0.0",
    "vite": "^6.0.7"
  }
}
