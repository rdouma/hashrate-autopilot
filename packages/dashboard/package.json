{
  "name": "@hashrate-autopilot/dashboard",
  "version": "0.1.0",
  "description": "React SPA for the Hashrate Autopilot",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm lingui:compile && tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "lingui:extract": "lingui extract --clean",
    "lingui:compile": "lingui compile --typescript"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hashrate-autopilot/shared": "workspace:*",
    "@lingui/core": "^6.2.0",
    "@lingui/react": "^6.2.0",
    "@tanstack/react-query": "^5.101.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.17.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@lingui/babel-plugin-lingui-macro": "^6.2.0",
    "@lingui/cli": "^6.2.0",
    "@lingui/format-po": "^6.2.0",
    "@lingui/vite-plugin": "^6.2.0",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.16"
  }
}
