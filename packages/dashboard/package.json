{
  "name": "@braiins-hashrate/dashboard",
  "version": "0.1.0",
  "description": "React SPA for the Braiins hashrate autopilot",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm lingui:compile && tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "lingui:extract": "lingui extract --clean",
    "lingui:compile": "lingui compile --typescript"
  },
  "dependencies": {
    "@braiins-hashrate/shared": "workspace:*",
    "@lingui/core": "^5.9.5",
    "@lingui/macro": "^5",
    "@lingui/react": "^5.9.5",
    "@tanstack/react-query": "^5.64.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.2"
  },
  "devDependencies": {
    "@lingui/cli": "^5.9.5",
    "@lingui/vite-plugin": "^5.9.5",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "babel-plugin-macros": "^3.1.0",
    "tailwindcss": "^4.0.0",
    "vite": "^6.0.7"
  }
}
