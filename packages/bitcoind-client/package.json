{
  "name": "@hashrate-autopilot/bitcoind-client",
  "version": "0.1.0",
  "description": "Minimal JSON-RPC client for bitcoind (payout observation)",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b tsconfig.json --force",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
